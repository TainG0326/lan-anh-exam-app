{
  "name": "exam-lockdown-app",
  "version": "1.0.0",
  "description": "Lockdown Exam Browser - Safe Exam Browser Alternative",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "dev": "electron . --dev"
  },
  "keywords": ["exam", "lockdown", "electron"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "@tensorflow/tfjs": "^4.15.0",
    "@tensorflow-models/blazeface": "^2.0.6",
    "crypto-js": "^4.2.0"
  },
  "build": {
    "appId": "com.exam.lockdown",
    "productName": "Exam Lockdown Browser",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    }
  }
}



