{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "vite",
  "devCommand": "npm run dev",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "env": {
    "VITE_API_URL": "https://english-exam-api-oksd.onrender.com/api",
    "VITE_REDIRECT_URL": "https://student-web-sigma.vercel.app/auth/callback"
  }
}
