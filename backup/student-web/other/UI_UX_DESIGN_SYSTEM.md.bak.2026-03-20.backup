      <tbody className="divide-y divide-border">
        {rows.map((row, i) => (
          <tr key={row.id} className="hover:bg-surface/80 transition-colors">
            <td className="px-4 py-3 text-sm text-text-primary">{row.content}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</div>
```

### 3.9 Modals

```tsx
{/* Backdrop */}
<div className="fixed inset-0 bg-black/40 backdrop-blur-sm z-50 animate-fade-in" />

{/* Content */}
<motion.div
  initial={{ opacity: 0, scale: 0.95 }}
  animate={{ opacity: 1, scale: 1 }}
  exit={{ opacity: 0, scale: 0.95 }}
  transition={{ duration: 0.3, ease: [0.4, 0, 0.2, 1] }}
  className="fixed inset-0 z-60 flex items-center justify-center p-4 pointer-events-none"
>
  <div className="bg-white rounded-2xl shadow-xl max-w-lg w-full max-h-[90vh] overflow-auto pointer-events-auto">
    {/* Header */}
    <div className="flex items-center justify-between px-6 py-4 border-b border-border">
      <h3 className="text-lg font-semibold text-text-primary">{title}</h3>
      <button className="w-8 h-8 rounded-lg flex items-center justify-center hover:bg-surface text-text-muted hover:text-text-primary transition-colors">
        <X className="w-5 h-5" />
      </button>
    </div>
    {/* Body */}
    <div className="p-6">
      {/* Content */}
    </div>
    {/* Footer */}
    <div className="flex justify-end gap-3 px-6 py-4 border-t border-border">
      <Button variant="outline">Hủy</Button>
      <Button variant="primary">Xác nhận</Button>
    </div>
  </div>
</motion.div>
```

**Modal Sizes**:
| Name | Class | Usage |
|---|---|---|
| sm | `max-w-md` | Confirm, small info |
| md | `max-w-lg` | Standard form |
| lg | `max-w-2xl` | Complex form, preview |
| full | `max-w-[95vw] max-h-[95vh]` | Exam taking interface |

### 3.10 Avatar

```tsx
// With image
<div className="w-10 h-10 rounded-full overflow-hidden ring-2 ring-white shadow-sm flex-shrink-0">
  <img src={url} alt={name} className="w-full h-full object-cover" />
</div>

// With initials fallback
<div className="w-10 h-10 rounded-full bg-gradient-to-br from-primary to-secondary
                flex items-center justify-center text-white font-semibold text-sm flex-shrink-0">
  {initials}
</div>

// Avatar with online indicator
<div className="relative">
  <Avatar user={user} />
  <div className="absolute bottom-0 right-0 w-3 h-3 bg-green-500 rounded-full ring-2 ring-white" />
</div>
```

**Avatar Sizes**: `w-6 h-6` (xs), `w-8 h-8` (sm), `w-10 h-10` (md), `w-12 h-12` (lg), `w-16 h-16` (xl)

### 3.11 Dropdowns

```tsx
<div className="relative">
  <button ref={ref} onClick={() => setOpen(!open)} className="flex items-center gap-2">
    {trigger}
  </button>
  <AnimatePresence>
    {open && (
      <motion.div
        initial={{ opacity: 0, y: -8 }}
        animate={{ opacity: 1, y: 0 }}
        exit={{ opacity: 0, y: -8 }}
        transition={{ duration: 0.2 }}
        className="absolute right-0 mt-2 w-56 bg-white rounded-xl shadow-lg border border-border z-50 py-1"
      >
        {/* Menu items */}
      </motion.div>
    )}
  </AnimatePresence>
</div>
```

